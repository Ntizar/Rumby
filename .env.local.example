# Variables de entorno reales (NO se commitean).
# Copia este archivo a `.env.local` y rellena los valores.

# NAP - Punto de Acceso Nacional (transportes.gob.es)
# Solicitar en https://nap.transportes.gob.es/Account/SignIn
NAP_API_KEY=

# Transit.land - Mirror de feeds GTFS por ciudad/operador.
# Cuenta gratis en https://www.transit.land/operators/sign_up
# Sin esta key, /api/gtfs/stops devuelve [] y los modos transit caen a estimacion.
TRANSITLAND_API_KEY=

# Override opcional: URL directa al ZIP GTFS por ciudad/modo.
# Si esta presente, se usa antes que Transit.land.
# GTFS_MADRID_TRANSIT_URL=
# GTFS_BARCELONA_TRANSIT_URL=
